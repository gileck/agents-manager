{
  "name": "electron-macos-template",
  "version": "1.0.0",
  "description": "Production-ready Electron template for macOS menu bar apps",
  "main": "bootstrap.js",
  "bin": {
    "agents-manager": "./bootstrap-cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist dist-main dist-cli dist-daemon dist-web",
    "build": "npm run clean && npm run build:main && npm run build:preload && npm run build:renderer && npm run build:web && npm run build:daemon",
    "build:main": "tsc -p config/tsconfig.main.json",
    "build:preload": "tsc -p config/tsconfig.preload.json",
    "build:renderer": "webpack --config config/webpack.renderer.config.js",
    "rebuild:electron": "npx @electron/rebuild -f -w better-sqlite3",
    "rebuild:node": "cd node_modules/better-sqlite3 && rm -rf build-node && mv build build-electron-bak 2>/dev/null; npx prebuild-install -r node && mv build build-node; mv build-electron-bak build 2>/dev/null; true",
    "prestart": "pkill -f 'Agents Manager' 2>/dev/null || true; pkill -f 'electron .' 2>/dev/null || true; pkill -f Electron 2>/dev/null || true; (test -f ~/.agents-manager/daemon.pid && kill $(cat ~/.agents-manager/daemon.pid) 2>/dev/null && rm -f ~/.agents-manager/daemon.pid) || true",
    "start": "npm run rebuild:electron && npm run build && electron .",
    "start:electron": "npm run rebuild:electron && npm run build && electron .",
    "start:devtools": "npm run rebuild:electron && npm run build && ELECTRON_DEBUG=1 electron .",
    "start:daemon": "npm run build:web && npm run build:daemon && BETTER_SQLITE3_BINDING=node_modules/better-sqlite3/build-node/Release/better_sqlite3.node node dist-daemon/index.js",
    "start:web": "npm run build:web && npm run build:daemon && BETTER_SQLITE3_BINDING=node_modules/better-sqlite3/build-node/Release/better_sqlite3.node node dist-daemon/index.js",
    "electron": "electron .",
    "electron:debug": "ELECTRON_DEBUG=1 electron .",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p config/tsconfig.main.json --watch",
    "dev:preload": "tsc -p config/tsconfig.preload.json --watch",
    "dev:renderer": "webpack --config config/webpack.renderer.config.js --watch",
    "pack": "npm run rebuild:electron && npm run build && electron-builder --dir",
    "dist": "npm run rebuild:electron && npm run build && electron-builder",
    "deploy": "./scripts/deploy.sh",
    "build:cli": "tsc -p config/tsconfig.cli.json",
    "build:web": "webpack --config config/webpack.web.config.js",
    "build:web:prod": "NODE_ENV=production webpack --config config/webpack.web.config.js",
    "dev:web": "webpack serve --config config/webpack.web.config.js",
    "dev:daemon": "npx tsx scripts/dev-daemon.ts",
    "ensure-native": "node scripts/ensure-native-binding.js",
    "dev:start": "npm run ensure-native && npx tsx scripts/dev-daemon.ts --web",
    "build:daemon": "esbuild src/daemon/index.ts --bundle --platform=node --outfile=dist-daemon/index.js --external:better-sqlite3 --external:node-telegram-bot-api",
    "lint": "eslint src/ template/ tests/",
    "typecheck": "tsc --noEmit -p config/tsconfig.main.json && tsc --noEmit -p config/tsconfig.preload.json && tsc --noEmit -p config/tsconfig.renderer.json && tsc --noEmit -p config/tsconfig.cli.json && tsc --noEmit -p config/tsconfig.daemon.json && tsc --noEmit -p config/tsconfig.web.json",
    "typecheck:web": "tsc --noEmit -p config/tsconfig.web.json",
    "checks": "yarn typecheck && yarn lint",
    "build:claude": "npx tsx ~/.claude/skills/build-claude-md/index.ts CLAUDE.md",
    "test": "npm run ensure-native && BETTER_SQLITE3_BINDING=node_modules/better-sqlite3/build-node/Release/better_sqlite3.node vitest run",
    "test:watch": "npm run ensure-native && BETTER_SQLITE3_BINDING=node_modules/better-sqlite3/build-node/Release/better_sqlite3.node vitest",
    "test:coverage": "BETTER_SQLITE3_BINDING=node_modules/better-sqlite3/build-node/Release/better_sqlite3.node vitest run --coverage",
    "test:e2e:libs": "vitest run --config vitest.e2e-libs.config.ts",
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3 && npm run rebuild:node"
  },
  "keywords": [
    "electron",
    "macos",
    "template",
    "menu-bar-app"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@openai/codex-sdk": "0.106.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "cron-parser": "^4.9.0",
    "date-fns": "^3.6.0",
    "express": "^5.2.1",
    "konva": "^10.2.0",
    "lucide-react": "^0.469.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-konva": "^19.2.2",
    "react-markdown": "9",
    "react-router-dom": "^6.28.1",
    "remark-gfm": "4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^10.0.0",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.1.2",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "electron": "^40.2.1",
    "electron-builder": "^26.4.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0-rc.2",
    "html-webpack-plugin": "^5.6.5",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "ts-loader": "^9.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.1-alpha.5",
    "vitest": "^4.0.18",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "build": {
    "appId": "com.agents-manager.app",
    "productName": "Agents Manager",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dir",
      "icon": "assets/icon.icns"
    },
    "files": [
      "bootstrap.js",
      "dist-main/**/*",
      "dist/**/*",
      "dist-daemon/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release/better_sqlite3.node",
        "to": "better_sqlite3.node"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
